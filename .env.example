# Base de datos (Supabase o PostgreSQL local)
DATABASE_URL="postgresql://usuario:password@host:5432/guemajim"

# Auth — generar con: openssl rand -base64 32
AUTH_SECRET="tu_secret_aqui"

# Admin inicial (usado en el seed)
ADMIN_EMAIL="admin@guemajim.com"
ADMIN_PASSWORD="CambiarEstaPassword!"

# Email (Resend — https://resend.com)
RESEND_API_KEY="re_xxxxxxxxxxxx"
EMAIL_FROM="no-reply@guemajim.com"

# URL de la app
NEXTAUTH_URL="http://localhost:3000"
